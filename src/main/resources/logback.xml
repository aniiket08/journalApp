<configuration>

    <appender name = "myConsoleAppender" class = "ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>


    <appender name = "myFileAppender" class = "ch.qos.logback.core.FileAppender">
<!--        We can use rolling.RollingFileAppender instead of core.FIleApeender   -->
        <file>
            journalApp.log

<!--        This File Shouldn't be in the Project Folder. We will create it outside the Project Folder
            and give the Path Of File Here        -->
        </file>
    </appender>


    <root level = "INFO">
        <appender-ref ref = "myConsoleAppender" />
        <appender-ref ref="myFileAppender" />
    </root>

</configuration>